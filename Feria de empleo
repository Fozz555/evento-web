<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feria de Empleo Madrid 2026</title>
  
  <!-- Bootstrap CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
        rel="stylesheet" 
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" 
        crossorigin="anonymous">
  
  <style>
    /* Estilos básicos */
    .fondo-hero {
      background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), 
                  url('https://images.unsplash.com/photo-1557804506-669a67965ba0?auto=format&fit=crop&q=80') center/cover;
      color: white;
      padding: 100px 0;
    }
    
    h2.section-titulo {
      position: relative;
      margin-bottom: 2rem;
    }
    
    h2.section-titulo:after {
      content: '';
      display: block;
      width: 60px;
      height: 4px;
      background: #0d6efd;
      margin: 10px auto 0;
    }
    
    footer {
      background: #1a2537;
      color: #adb5bd;
      padding: 2rem 0;
    }
    
    /* Quitar subrayado en enlaces y botones */
    a, .nav-link, .btn {
      text-decoration: none !important;
    }
    
    a:hover, .nav-link:hover, .btn:hover {
      text-decoration: none !important;
    }
    
    /* Feedback sutil en hover para botones */
    .btn:hover {
      opacity: 0.9;
    }

    /* Espacio para que el contenido no quede debajo del header */
    body {
      padding-top: 60px;
    }
  </style>
</head>
<body>

  <!-- Navbar sencilla -->
  <nav class="navbar navbar-dark bg-dark fixed-top">
    <div class="container d-flex justify-content-between align-items-center">
      <a class="navbar-brand" href="#">Feria Empleo 2026</a>
      <div>
        <a class="nav-link d-inline-block text-white me-3" href="#inicio">Inicio</a>
        <a class="nav-link d-inline-block text-white me-3" href="#cuando">Cuándo y dónde</a>
        <a class="nav-link d-inline-block text-white me-3" href="#empresas">Empresas</a>
        <a href="https://forms.gle/ejemplo-inscripcion" target="_blank" class="btn btn-primary btn-sm">
          Inscríbete
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section id="inicio" class="fondo-hero text-center">
    <div class="container">
      <h1 class="display-4 fw-bold mb-4">Feria de Empleo Madrid 2026</h1>
      <p class="lead mb-4">Encuentra trabajo, entrega CV y habla directamente con empresas</p>
      <p>Más de 50 empresas • Ofertas reales • Asesoramiento gratis</p>
      <a href="https://forms.gle/ejemplo-inscripcion" class="btn btn-dark btn-lg mt-3">Apúntate ya</a>
    </div>
  </section>

  <!-- Cuándo y dónde -->
  <section id="cuando" class="py-5 bg-light">
    <div class="container">
      <h2 class="text-center section-titulo">¿Cuándo y dónde se celebra?</h2>
      <div class="row g-4">
        <div class="col-lg-6">
          <div class="card shadow-sm h-100">
            <div class="card-body p-4">
              <h4 class="text-primary">Fechas y horario</h4>
              <ul class="list-unstyled mt-3">
                <li><strong>Fechas:</strong> 15 y 16 de mayo de 2026</li>
                <li><strong>Horario:</strong> de 10:00 a 18:00 h</li>
                <li><strong>Entrada:</strong> Gratuita (mejor inscribirse antes)</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card shadow-sm h-100">
            <div class="card-body p-4">
              <h4 class="text-primary">Lugar</h4>
              <ul class="list-unstyled mt-3">
                <li><strong>Sitio:</strong> La Nave (Centro de Innovación)</li>
                <li><strong>Dirección:</strong> C/ Cifuentes 5, Villaverde, Madrid</li>
                <li><strong>Cómo llegar:</strong> Metro Línea 3 (Villaverde Alto) o bus</li>
                <li><strong>Parking:</strong> Hay zonas cercanas</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Empresas -->
  <section id="empresas" class="py-5">
    <div class="container">
      <h2 class="text-center section-titulo">Algunas empresas que vienen</h2>
      <div class="row g-4 text-center">
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5>Tecnología</h5>
              <p class="text-muted">Indra, Telefónica, Accenture, Amazon, Everis...</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5>Banca y Seguros</h5>
              <p class="text-muted">BBVA, Santander, Mapfre, CaixaBank...</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5>Otros sectores</h5>
              <p class="text-muted">Mahou, Nestlé, SEAT, Correos, DHL...</p>
            </div>
          </div>
        </div>
      </div>
      <p class="text-center mt-4 text-muted">La lista completa se publicará más cerca de la fecha</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="text-center">
    <div class="container">
      <p class="mb-1">Feria de Empleo Madrid 2026 – Organizado con apoyo de la Comunidad de Madrid</p>
      <p class="small mb-0">Más info: empleo2026@madrid.es | 91 234 56 78</p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" 
          integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" 
          crossorigin="anonymous"></script>
</body>
</html>
