<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Feria de Empleo 2026 - Conecta con tu futuro laboral</title>
  
  <!-- Bootstrap 5 CSS CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
        rel="stylesheet" 
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" 
        crossorigin="anonymous">
  
  <!-- Estilos personalizados mínimos -->
  <style>
    .hero {
      background: linear-gradient(rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0.55)), 
                  url('https://images.unsplash.com/photo-1551836022-d5d88e9218df?ixlib=rb-4.0.3&auto=format&fit=crop&w=1350&q=80') center center;
      background-size: cover;
      color: white;
      padding: 120px 0 100px;
    }
    
    .section-title {
      position: relative;
      margin-bottom: 2.5rem;
    }
    
    .section-title::after {
      content: '';
      width: 80px;
      height: 4px;
      background-color: #0d6efd;
      position: absolute;
      bottom: -12px;
      left: 50%;
      transform: translateX(-50%);
    }
    
    footer {
      background-color: #0d1a40;
      color: #cbd5e1;
    }
  </style>
</head>
<body>

  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm fixed-top">
    <div class="container">
      <a class="navbar-brand fw-bold" href="#">Feria Empleo 2026</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" 
              data-bs-target="#navbarNav" aria-controls="navbarNav" 
              aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="#inicio">Inicio</a></li>
          <li class="nav-item"><a class="nav-link" href="#cuando">Cuándo y dónde</a></li>
          <li class="nav-item"><a class="nav-link" href="#empresas">Empresas</a></li>
          <li class="nav-item"><a class="nav-link" href="#programa">Programa</a></li>
          <li class="nav-item"><a class="nav-link btn btn-outline-light ms-2" href="#">Inscríbete</a></li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section id="inicio" class="hero text-center text-white">
    <div class="container">
      <h1 class="display-3 fw-bold mb-4">Feria de Empleo 2026</h1>
      <p class="lead fs-4 mb-4">La oportunidad más importante del año para encontrar trabajo</p>
      <p class="fs-5 mb-5">Más de 60 empresas • +2.000 ofertas • Asesoramiento profesional gratuito</p>
      <a href="#" class="btn btn-primary btn-lg px-5 py-3">¡Regístrate ahora!</a>
    </div>
  </section>

  <!-- Sección 1: Cuándo y dónde + Información esencial (grid 2 columnas en lg) -->
  <section id="cuando" class="py-5 bg-light">
    <div class="container">
      <h2 class="text-center section-title mb-5">¿Cuándo y dónde?</h2>
      <div class="row g-5 align-items-center">
        <div class="col-lg-6">
          <div class="card shadow h-100 border-0">
            <div class="card-body p-5">
              <h3 class="card-title text-primary mb-4">Fecha y horario</h3>
              <ul class="list-unstyled fs-5">
                <li class="mb-3"><strong>Fecha:</strong> 15 y 16 de mayo de 2026</li>
                <li class="mb-3"><strong>Horario:</strong> 10:00 – 18:00 h</li>
                <li><strong>Entrada:</strong> Gratuita (inscripción recomendada)</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="card shadow h-100 border-0">
            <div class="card-body p-5">
              <h3 class="card-title text-primary mb-4">Lugar</h3>
              <ul class="list-unstyled fs-5">
                <li class="mb-3"><strong>Recinto:</strong> Palacio de Congresos y Exposiciones</li>
                <li class="mb-3"><strong>Dirección:</strong> Av. Capital, 45 – 28001 Madrid</li>
                <li class="mb-3"><strong>Metro:</strong> Líneas 2 y 6 – Estación Nuevos Ministerios</li>
                <li><strong>Parking:</strong> Más de 800 plazas gratuitas</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección 2: Empresas participantes + Programa (grid 2 columnas en lg) -->
  <section id="empresas" class="py-5">
    <div class="container">
      <h2 class="text-center section-title mb-5">Empresas participantes</h2>
      <div class="row g-4">
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body text-center p-4">
              <h5 class="card-title">Tecnología y Desarrollo</h5>
              <p class="card-text text-muted">Google • Amazon • Microsoft • Indra • Accenture • Telefónica</p>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body text-center p-4">
              <h5 class="card-title">Banca y Finanzas</h5>
              <p class="card-text text-muted">BBVA • Santander • CaixaBank • Mapfre • ING • Bankinter</p>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm border-0">
            <div class="card-body text-center p-4">
              <h5 class="card-title">Industria y Logística</h5>
              <p class="card-text text-muted">SEAT • Airbus • DHL • Amazon Logistics • Nestlé • Mahou</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-4 text-center">
    <div class="container">
      <p class="mb-2">Feria de Empleo 2026 © 2026 – Organizado por el Ayuntamiento de Madrid y la Comunidad de Madrid</p>
      <p class="mb-1 small">Para más información: empleo2026@madrid.es | 91 123 45 67</p>
    </div>
  </footer>

  <!-- Bootstrap 5 JS CDN (necesario para componentes interactivos) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" 
          integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" 
          crossorigin="anonymous"></script>
</body>
</html>
